# Neon Postgres — pooled connection (PgBouncer) for app runtime
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require&pgbouncer=true

# Neon Postgres — unpooled (direct) connection for Prisma migrations
DIRECT_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# Upstash Redis (rate limiting / cache)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# CFBD API
CFBD_API_KEY=your_cfbd_api_key
