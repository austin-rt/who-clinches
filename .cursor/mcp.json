{
  "mcpServers": {
    "Neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp",
      "headers": {
        "Authorization": "Bearer ${env:NEON_API_KEY}"
      }
    },
    "logrocket": {
      "url": "https://mcp.logrocket.com/mcp"
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${env:GITHUB_PAT}"
      }
    },
    "upstash": {
      "command": "sh",
      "args": [
        "-c",
        "npx -y @upstash/mcp-server@latest --email austinrtaylor91@gmail.com --api-key $UPSTASH_API_KEY"
      ],
      "env": {
        "UPSTASH_API_KEY": "${env:UPSTASH_API_KEY}"
      }
    }
  }
}
