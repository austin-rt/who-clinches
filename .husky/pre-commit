#!/bin/sh

# Color codes
RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# 1. Block direct commits to main
branch=$(git symbolic-ref HEAD 2>/dev/null | cut -d"/" -f 3)
if [ "$branch" = "main" ]; then
  printf "${RED}ERROR: Cannot commit directly to main branch${NC}\n"
  printf "${YELLOW}Switch to develop: git checkout develop${NC}\n"
  exit 1
fi

# 2. Block commits to temp/ directory (except README.md)
TEMP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^temp/" | grep -v "^temp/README.md$" || true)
if [ -n "$TEMP_FILES" ]; then
  printf "${RED}ERROR: Cannot commit files in temp/ directory (except README.md)${NC}\n"
  printf "${YELLOW}Found:${NC}\n"
  echo "$TEMP_FILES" | while read -r file; do
    printf "  ${YELLOW}$file${NC}\n"
  done
  printf "${YELLOW}Only temp/README.md is allowed to be committed.${NC}\n"
  exit 1
fi

# 3. Check for file-level eslint-disable comments
FILE_LEVEL_IGNORES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | xargs grep -l "eslint-disable\s*$" 2>/dev/null || true)
if [ -n "$FILE_LEVEL_IGNORES" ]; then
  printf "${RED}ERROR: File-level eslint-disable comments are not allowed${NC}\n"
  printf "${YELLOW}Found in:${NC}\n"
  echo "$FILE_LEVEL_IGNORES" | while read -r file; do
    line=$(grep -n "eslint-disable\s*$" "$file" | head -1 | cut -d: -f1)
    printf "  ${YELLOW}$file:$line${NC}\n"
  done
  printf "${YELLOW}Use line-specific comments instead: // eslint-disable-next-line rule-name${NC}\n"
  exit 1
fi

# 4. Run ESLint + Prettier + related Jest tests (via lint-staged) on staged files only
# Full tsc --noEmit runs on pre-push (see .husky/pre-push)
npx lint-staged
