#!/bin/sh

# 1. Block direct commits to main
branch=$(git symbolic-ref HEAD 2>/dev/null | cut -d"/" -f 3)
if [ "$branch" = "main" ]; then
  echo "❌ Cannot commit directly to main branch"
  echo "💡 Switch to develop: git checkout develop"
  exit 1
fi

# 2. Run ESLint + TypeScript checks (via lint-staged)
# This enforces: no console.log, no debugger, no 'any', no unused vars, etc.
npx lint-staged
