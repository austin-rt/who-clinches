generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model SimulationSnapshot {
  id        String   @id
  createdAt DateTime @default(now())
  sport     String
  conf      String
  season    Int
  payload   Json
  createdBy String?
  hash      String   @unique
}

model RuntimeConfig {
  id               String   @id @default("singleton")
  fixtureYearOn    Boolean  @default(false)
  fixtureYear      Int?
  graphqlOn        Boolean  @default(true)
  redisOn          Boolean  @default(true)
  rateLimitOn      Boolean  @default(true)
  inSeasonOverride Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  aiChatOn         Boolean  @default(false)
  ragOn            Boolean  @default(false)
  chatRateLimitOn  Boolean  @default(true)
}

model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String
  conf         String?
  teamId       String?
  teamName     String?
  promptHash   String?
  createdAt    DateTime @default(now())
  inputTokens  Int?
  outputTokens Int?

  @@index([sessionId])
  @@index([createdAt])
}

model ChatUser {
  id               String    @id @default(cuid())
  anonymousId      String    @unique
  email            String?   @unique
  purchasedCredits Int       @default(0)
  freeUsedInWindow Int       @default(0)
  windowExpiresAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([email])
}

model Donation {
  id         String   @id @default(cuid())
  bmcId      String   @unique
  email      String
  amount     Float
  credits    Int
  chatUserId String?
  createdAt  DateTime @default(now())

  @@index([email])
}

model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model Feedback {
  id        String   @id @default(cuid())
  sessionId String?
  message   String
  conf      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolved])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String                @id @default(cuid())
  sourceFile String
  conference String?
  section    String?
  content    String
  embedding  Unsupported("vector")
  tokenCount Int
  chunkIndex Int
  createdAt  DateTime              @default(now())
  batchId    String

  @@index([conference])
  @@index([batchId])
  @@index([embedding])
}
