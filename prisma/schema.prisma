generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SimulationSnapshot {
  id        String   @id
  createdAt DateTime @default(now())
  sport     String
  conf      String
  season    Int
  hash      String   @unique
  payload   Json
  createdBy String?
}
