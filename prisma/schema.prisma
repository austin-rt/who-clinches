generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model SimulationSnapshot {
  id        String   @id
  createdAt DateTime @default(now())
  sport     String
  conf      String
  season    Int
  hash      String   @unique
  payload   Json
  createdBy String?
}

model RuntimeConfig {
  id               String   @id @default("singleton")
  fixtureYearOn    Boolean  @default(false)
  fixtureYear      Int?
  graphqlOn        Boolean  @default(true)
  redisOn          Boolean  @default(true)
  rateLimitOn      Boolean  @default(true)
  inSeasonOverride Boolean  @default(false)
  aiChatOn         Boolean  @default(false)
  ragOn            Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  conf      String?
  teamId    String?
  teamName  String?
  promptHash   String?
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String                  @id @default(cuid())
  sourceFile String
  conference String?
  section    String?
  content    String
  embedding  Unsupported("vector(512)")
  tokenCount Int
  chunkIndex Int
  createdAt  DateTime                @default(now())
  batchId    String

  @@index([conference])
  @@index([batchId])
}
