generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SimulationSnapshot {
  id        String   @id
  createdAt DateTime @default(now())
  sport     String
  conf      String
  season    Int
  hash      String   @unique
  payload   Json
  createdBy String?
}

model RuntimeConfig {
  id               String   @id @default("singleton")
  fixtureYearOn    Boolean  @default(false)
  fixtureYear      Int?
  graphqlOn        Boolean  @default(true)
  redisOn          Boolean  @default(true)
  rateLimitOn      Boolean  @default(true)
  inSeasonOverride Boolean  @default(false)
  aiChatOn         Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  conf      String?
  teamId    String?
  teamName  String?
  promptHash String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}
