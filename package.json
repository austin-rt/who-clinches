{
  "name": "who-clinches",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run json-server\" \"next dev\"",
    "dev:next": "next dev",
    "kill": "pkill -f 'next dev' || pkill -f 'npm run dev' || true",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:all": "npm run test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest __tests__/api",
    "test:api:all": "tsx scripts/test-all-api-routes.ts",
    "test:sandbox": "tsx scripts/test-sandbox-api-routes.ts",
    "test:sandbox:cleanup": "tsx scripts/test-sandbox-api-routes.ts --cleanup",
    "test:reshape": "jest __tests__/lib/reshape-teams",
    "generate": "rtk-query-codegen-openapi rtk-query-codegen.config.js",
    "codegen": "rtk-query-codegen-openapi rtk-query-codegen.config.js",
    "json-server": "tsx scripts/json-server.ts",
    "capture-fixtures": "tsx scripts/capture-cfbd-fixtures.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0",
      "bash -c 'tsc --noEmit'"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.10.1",
    "cfbd": "^5.13.2",
    "city-timezones": "^1.3.2",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.0",
    "graphql-ws": "^5.14.2",
    "logrocket": "^10.1.1",
    "next": "16.0.7",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "redux-persist-expire": "^1.1.1",
    "redux-thunk": "^3.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/json-server": "^0.14.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "json-server": "^1.0.0-beta.3",
    "lint-staged": "^16.2.6",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.6",
    "postcss-nesting": "^13.0.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "quicktype": "^23.2.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
